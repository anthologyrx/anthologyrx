{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/style.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/main.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/favicon.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/favicon.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/treatments/glp-1",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/treatments/glp-1/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/treatments/gonadorelin",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/treatments/gonadorelin/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/treatments/pt-141",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/treatments/pt-141/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/treatments/tesamorelin",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/treatments/tesamorelin/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/treatments/ramelteon",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/treatments/ramelteon/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/treatments/micc",
      "destination": "/treatments/lipo-c",
      "permanent": true
    },
    {
      "source": "/treatments/micc/:path*",
      "destination": "/treatments/lipo-c",
      "permanent": true
    },
    {
      "source": "/qualify",
      "destination": "/#treatments",
      "permanent": true
    },
    {
      "source": "/qualify/",
      "destination": "/#treatments",
      "permanent": true
    },
    {
      "source": "/science",
      "destination": "/how-it-works",
      "permanent": true
    },
    {
      "source": "/science/:path*",
      "destination": "/how-it-works",
      "permanent": true
    }
  ]
}
