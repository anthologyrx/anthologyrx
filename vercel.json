{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/protocols", "destination": "/protocol-landing/index.html" },
    { "source": "/pricing", "destination": "/pricing-page/index.html" },
    { "source": "/product/:path*", "destination": "/product-page/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
