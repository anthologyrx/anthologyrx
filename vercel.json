{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/treatments",             "destination": "/treatments/index.html" },
    { "source": "/treatments/glp-1",       "destination": "/treatments/glp-1.html" },
    { "source": "/treatments/nad",         "destination": "/treatments/nad.html" },
    { "source": "/treatments/micc",        "destination": "/treatments/micc.html" },
    { "source": "/treatments/tesamorelin", "destination": "/treatments/tesamorelin.html" },
    { "source": "/treatments/pt-141",      "destination": "/treatments/pt-141.html" },
    { "source": "/qualify",                "destination": "/qualify/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
